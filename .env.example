# 复制为 .env 并填入真实值。.env 本身不提交。
# 本地开发默认对应 docker-compose.yml 里的 Postgres 配置。
DATABASE_URL="postgresql://pnr:pnr_dev_pw@localhost:5432/pnr_dev?schema=public"

# Session cookie 签名密钥，生产环境务必换成强随机值
SESSION_SECRET="change-me"

# development | production
NODE_ENV="development"

# 后端监听端口（生产 3001）
PORT="3001"

# 可选：覆盖 cookie 的 secure 属性。不设则按 NODE_ENV 自动判断（production=true）。
# 仅在备案前用 http://IP 临时访问时设为 false；上了 HTTPS 后删除或设 true。
# COOKIE_SECURE="false"
